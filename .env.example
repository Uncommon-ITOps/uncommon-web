# Local Postgres (e.g. postgresql://localhost:5432/uncommon_dev)
# Railway provides DATABASE_URL; map to DATABASE_URI if needed
DATABASE_URI=postgresql://localhost:5432/uncommon_dev
PAYLOAD_SECRET=any-random-string-for-local

